# Local development (point to local Express + Socket.io server).
# In production, set these in Vercel → Project → Settings → Environment Variables
# (scope: Production + Preview) to your Render backend URL, e.g.
#   VITE_API_URL=https://multiplayer-game.onrender.com
#   VITE_SOCKET_URL=https://multiplayer-game.onrender.com
VITE_API_URL=http://localhost:5000
VITE_SOCKET_URL=http://localhost:5000
